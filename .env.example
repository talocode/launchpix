# Public app URL used for auth/billing callbacks
NEXT_PUBLIC_APP_URL=http://localhost:3000
# OAuth callback base URL (defaults to NEXT_PUBLIC_APP_URL when unset)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Supabase client config
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase server/admin credentials
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Mistral AI (structured planning + image generation)
MISTRAL_API_KEY=
# Default: mistral-small-2506
MISTRAL_MODEL_VISION=mistral-small-2506
# Default: mistral-small-2506
MISTRAL_MODEL_TEXT=mistral-small-2506
# Default: mistral-medium-latest
MISTRAL_IMAGE_MODEL=mistral-medium-latest
# Optional: pre-created Mistral agent with the image_generation tool enabled.
# If omitted, LaunchPix creates one at runtime.
MISTRAL_IMAGE_AGENT_ID=
LAUNCHPIX_API_KEY=
# API generation mode (default: sync 201). Set true for async 202 + worker claim path.
LAUNCHPIX_ASYNC_GENERATION=
# When async is enabled, process queued jobs in-request (dev/single-node). Production should call
# POST /api/internal/worker/generations/process instead.
LAUNCHPIX_GENERATION_WORKER_INLINE=
# Secret for POST /api/internal/worker/generations/process (cron + manual replay).
LAUNCHPIX_WORKER_SECRET=
# Max queued generations processed per worker tick (default 5, max 20).
LAUNCHPIX_GENERATION_WORKER_BATCH_LIMIT=
# Allow force=true manual worker runs when async mode is disabled.
LAUNCHPIX_GENERATION_WORKER_ALLOW_MANUAL=
# Optional worker id label sent by scripts/process-generation-worker.ts
LAUNCHPIX_GENERATION_WORKER_ID=

# Lemon Squeezy credit billing
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_WEBHOOK_SECRET=
LEMON_SQUEEZY_STARTER_CREDITS_VARIANT_ID=
LEMON_SQUEEZY_CREATOR_CREDITS_VARIANT_ID=
LEMON_SQUEEZY_STUDIO_CREDITS_VARIANT_ID=
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_WEBHOOK_SECRET=

# Storage buckets
STORAGE_BUCKET_ASSETS=launchpix-assets
STORAGE_BUCKET_UPLOADS_RAW=project-uploads-raw
STORAGE_BUCKET_UPLOADS_NORMALIZED=project-uploads-normalized
